rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Blogs collection ──────────────────────────────────────────────────
    // PUBLIC: anyone (even unauthenticated visitors) can READ published posts
    // ADMIN:  only authenticated users can create, update, delete
    match /blogs/{blogId} {
      // Allow any visitor to read — blog is meant to be public
      allow read: if true;

      // Only the signed-in admin can write
      allow create, update, delete: if request.auth != null;
    }

    // ── All other documents: deny by default ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
